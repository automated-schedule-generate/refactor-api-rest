#!/bin/sh

echo "Atualizando branch com developer..."
git pull origin developer
echo "Branch atualizada!"

echo "Verificando nome da branch..."
branch=$(git rev-parse --abbrev-ref HEAD)

if ! echo "$branch" | grep -E "^(feat|feature|fix|hotfix|release|bugfix|docs|refactor|test)/[a-z0-9._-]+$"; then
  echo "❌ Nome da branch inválido!"
  echo "Use: feat/, feature/, fix/, hotfix/, release/, bugfix/, docs/, refactor/, test/"
  exit 1
fi
echo "Nome da branch verificado!"

echo "Executando lint-staged..."
npx lint-staged
echo "Lint-staged executado!"

echo "Adicionando arquivos..."
git add -A
echo "Arquivos adicionados!"
